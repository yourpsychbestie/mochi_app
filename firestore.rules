rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function codeExists(code) {
      return exists(/databases/$(database)/documents/codes/$(code));
    }

    function codeData(code) {
      return get(/databases/$(database)/documents/codes/$(code)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userCodeMatches(code) {
      return isSignedIn()
        && userExists()
        && userData().code is string
        && userData().code == code;
    }

    function isCodeParticipant(code) {
      return isSignedIn()
        && code is string
        && (
          (
            codeExists(code)
            && (
              codeData(code).ownerUid == request.auth.uid
              || codeData(code).partnerUid == request.auth.uid
              // Legacy fallback: older code docs may not have ownerUid/partnerUid yet.
              || (
                request.auth.token.email != null
                && codeData(code).ownerEmail == request.auth.token.email
              )
              || (
                request.auth.token.email != null
                && codeData(code).partnerEmail == request.auth.token.email
              )
            )
          )
          || userCodeMatches(code)
        );
    }

    function canCreateCoupleScoped() {
      return isSignedIn()
        && request.resource.data.coupleCode is string
        && isCodeParticipant(request.resource.data.coupleCode);
    }

    function canAccessStoredCoupleScoped() {
      return isSignedIn()
        && resource.data.coupleCode is string
        && isCodeParticipant(resource.data.coupleCode);
    }

    function keepsCoupleCodeStable() {
      return request.resource.data.coupleCode is string
        && resource.data.coupleCode is string
        && request.resource.data.coupleCode == resource.data.coupleCode;
    }

    // ── codes ────────────────────────────────────────────────────────────
    // Allow public READ so unauthenticated users can look up a partner's
    // code before registering (join flow calls fbGetCode before fbRegister).
    match /codes/{code} {
      allow read:  if true;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid
        || resource.data.partnerUid == request.auth.uid
        || (
          !(resource.data.partnerUid is string)
          && request.resource.data.partnerUid == request.auth.uid
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.ownerEmail == resource.data.ownerEmail
        )
      );
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // ── users ────────────────────────────────────────────────────────────
    // Each user can read/write their own document.
    // Partners need read access to update shared names.
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── progress ─────────────────────────────────────────────────────────
    match /progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /bamboo/{coupleCode} {
      allow read, write: if isCodeParticipant(coupleCode);
    }

    match /garden/{coupleCode} {
      allow read, write: if isCodeParticipant(coupleCode);
    }

    match /tests/{coupleCode} {
      allow read, write: if isCodeParticipant(coupleCode);
    }

    match /streaks/{coupleCode} {
      allow read, write: if isCodeParticipant(coupleCode);
    }

    match /messages/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /gratitud/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /momentos/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /conoce/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /lessons/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /burbuja/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /notifs/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /streakInteractions/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /exSessions/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /games/{docId} {
      allow create: if canCreateCoupleScoped();
      allow read, delete: if canAccessStoredCoupleScoped();
      allow update: if canAccessStoredCoupleScoped() && keepsCoupleCodeStable();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
