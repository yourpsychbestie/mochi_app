rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── codes ────────────────────────────────────────────────────────────
    // Allow public READ so unauthenticated users can look up a partner's
    // code before registering (join flow calls fbGetCode before fbRegister).
    // Only authenticated users may write.
    match /codes/{code} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── users ────────────────────────────────────────────────────────────
    // Each user can read/write their own document.
    // Partners need read access to update shared names.
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── progress ─────────────────────────────────────────────────────────
    match /progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── All other couple collections ──────────────────────────────────────
    // (messages, gratitud, momentos, conoce, lessons, burbuja, notifs,
    //  streakInteractions, bamboo, garden, tests, streaks, etc.)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
